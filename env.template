# FacilityTruth — Railway Environment Variables
# Add all of these in Railway → Your Project → Variables

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid
SENDGRID_API_KEY=SG....

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database (Railway PostgreSQL — auto-populated if you add a Postgres service)
DATABASE_URL=postgresql://...

# Notification email — where owner alerts go
NOTIFY_EMAIL=support@facilitytruth.com

# Google Document AI (optional — for high-quality OCR on scanned contracts)
# Leave blank to use Tesseract fallback
GOOGLE_DOCUMENT_AI_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
